{
  "name": "taygedo-daily-attendance",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "cf:dev": "wrangler dev",
    "deploy": "node scripts/resolve-kv-binding.mjs && wrangler deploy --config .wrangler/resolved.jsonc",
    "check": "for f in src/*.js public/*.js; do node --check \"$f\"; done"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
